# rendy-flow .env example (copy to .env and edit values)

# OpenAI / embeddings
OPENAI_API_KEY=your-openai-key
# Default chat + embedding models (adjust as needed)
# Chat model used by runtime/HTTP demos
OPENAI_CHAT_MODEL=gpt-4o-mini
# Embedding model used by ETL scripts (must match Pinecone index dimension)
OPENAI_EMBED_MODEL=text-embedding-3-small

# Pinecone (serverless) defaults used by scripts that support auto-create
PINECONE_API_KEY=your-pinecone-key
PINECONE_INDEX=my-index
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Postgres (CSV -> Postgres workflow)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=secret
PGDATABASE=analytics
PGSSLMODE=prefer

# Optional: short system prompt for HTTP demo (or paste contents from a file in SRC/)
SYSTEM_TEXT=You are Rendy, an assistant that reasons over organization knowledge.

# Optional: GitHub token for private repos when using ETL/GITHUB-Pinecone
# GITHUB_TOKEN=
